# Copy this file to `whatsapp_fte/.env` and fill in your own values.
# Both ADK (OpenAI) and the WhatsApp MCP server read that single file.
# NEVER commit the real .env — it is git-ignored.

# --- Model (OpenAI via LiteLlm) ---
OPENAI_API_KEY=

# --- WhatsApp Cloud API (Meta Developer > WhatsApp > API Setup) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# --- Webhook: owner / booking-team WhatsApp number (for approval routing) ---
# Number that receives booking approval requests and replies YES/NO.
# Must be a DIFFERENT verified test number than the customer's.
WHATSAPP_OWNER_NUMBER=

# --- Network workaround (optional) ---
# Set to 1 only if your network's IPv4 route to graph.facebook.com is broken
# (WhatsApp sends time out) but IPv6 works. Forces requests to use IPv6.
# Leave empty/unset on normal networks and in production.
FORCE_IPV6=
